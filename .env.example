AUTOSCALER_RPS_SCALE_UP_THRESHOLD=25.0
AUTOSCALER_CPU_SCALE_DOWN_THRESHOLD=20.0
AUTOSCALER_RPS_SCALE_DOWN_THRESHOLD=10.0
AUTOSCALER_SCALE_DOWN_CONSECUTIVE_CHECKS=3

DOCKER_NETWORK=aws-light-data
PROXY_REQUIRE_AUTH=false
